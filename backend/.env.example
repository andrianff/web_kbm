# KBM Backend Environment Variables Template
# Copy this to .env and adjust for local development

# Port server (Default: 8080)
PORT=8080

# Koneksi Database MySQL
# Format: username:password@tcp(host:port)/dbname?charset=utf8mb4&parseTime=True&loc=Local
# Untuk Laragon lokal biasanya: root:@tcp(127.0.0.1:3306)/kbm?charset=utf8mb4&parseTime=True&loc=Local
DB_DSN=root:@tcp(127.0.0.1:3306)/kbm?charset=utf8mb4&parseTime=True&loc=Local

# CORS Allowed Origins (Comma separated)
# Diisi dengan URL Frontend (Vercel) nanti
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
